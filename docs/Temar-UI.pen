                            { "type": "text", "id": "ed-p1", "content": "Backpropagation is the primary algorithm used to train neural networks. It computes gradients of the loss function with respect to each weight by applying the chain rule.", "fontSize": 15, "textColor": "#D4D4D8", "width": 900 },
                            {
                              "type": "frame", "id": "ed-code", "width": 900, "height": 80, "fill": "#0D0D0D", "cornerRadius": 8, "stroke": { "type": "solid", "color": "#27272A", "width": 1 }, "layout": "vertical", "padding": 12,
