                                { "type": "text", "id": "ec-code", "content": "loss.backward()\noptimizer.step()", "fontSize": 13, "textColor": "#A5F3FC", "fontFamily": "monospace" }
                              ]
                            },
                            { "type": "text", "id": "ed-p2", "content": "The key insight is that the gradient at each layer depends on the gradients of subsequent layers, hence the name \"back\" propagation.", "fontSize": 15, "textColor": "#D4D4D8", "width": 900 }
