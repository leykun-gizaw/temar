(cloudflare_tls) {
	tls /etc/caddy/certs/origin.pem /etc/caddy/certs/origin-key.pem
}

{$DOMAIN:localhost} {
	import cloudflare_tls

	# Payment provider webhooks — forwarded to the web app
	handle /api/webhooks/* {
		reverse_proxy web:5173
	}

	# Next.js web app (everything else)
	handle {
		reverse_proxy web:5173
	}

	# Encode responses with gzip/zstd
	encode zstd gzip

	# Security headers
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
	}
}

# Bare domain → www redirect
temar.app {
	import cloudflare_tls
	redir https://www.temar.app{uri} permanent
}

# Admin panel
admin.temar.app {
	import cloudflare_tls
	reverse_proxy admin:{$ADMIN_PORT:3000}

	encode zstd gzip

	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
	}
}